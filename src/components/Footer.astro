---
import site from '../content/site.json';

const programLinks = [
  { label: 'Nile Arabic Course', href: '/program/arabic-course' },
  { label: 'Pendaftaran Al-Azhar', href: '/program/pendaftaran-al-azhar' },
  { label: 'Nile Global Discovery', href: '/program/global-discovery' },
];
const aboutLinks = [
  { label: 'Selayang Pandang', href: '/tentang/selayang-pandang' },
  { label: 'Testimoni', href: '/tentang/testimoni' },
  { label: 'Our Team', href: '/tentang/team' },
  { label: 'Mitra', href: '/mitra' },
];
const freeLinks = [
  { label: 'Tes Kemampuan B. Arab', href: '/layanan/tes-bahasa-arab' },
  { label: 'Ebook Panduan Beasiswa', href: '/layanan/ebook-beasiswa' },
  { label: 'List Beasiswa', href: '/layanan/list-beasiswa' },
  { label: 'Konsultasi', href: '/layanan/konsultasi' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/images/logo.png" alt={site.companyName} />
        <p>{site.companyName} — {site.tagline}.</p>
        <p class="footer-addr">{site.address}</p>
      </div>
      <div class="footer-col">
        <h4>Program</h4>
        {programLinks.map(l => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="footer-col">
        <h4>Tentang Kami</h4>
        {aboutLinks.map(l => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="footer-col">
        <h4>Layanan Gratis</h4>
        {freeLinks.map(l => <a href={l.href}>{l.label}</a>)}
        <h4 class="mt">Contact Person</h4>
        {site.contacts.map(c => (
          <a href={`https://wa.me/${c.whatsapp}`}>{c.name}</a>
        ))}
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 {site.companyName}. All Rights Reserved.</span>
      <div class="footer-socials">
        <a href={site.social.instagram} target="_blank" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href={site.social.facebook} target="_blank" aria-label="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.47h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385c5.738-.9 10.126-5.864 10.126-11.854z"/></svg>
        </a>
        <a href={site.social.tiktok} target="_blank" aria-label="TikTok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--navy); color: rgba(255,255,255,0.6); padding: 64px 0 32px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.2fr; gap: 48px; margin-bottom: 48px; }
  .footer-brand img { height: 48px; margin-bottom: 16px; filter: brightness(0) invert(1); }
  .footer-brand > p { font-size: 0.85rem; line-height: 1.8; }
  .footer-addr { font-size: 0.82rem; margin-top: 8px !important; }
  .footer-col h4 { color: var(--gold-light); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
  .footer-col .mt { margin-top: 24px; }
  .footer-col a { display: block; font-size: 0.85rem; padding: 4px 0; transition: var(--transition); }
  .footer-col a:hover { color: var(--gold-light); }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.08); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; font-size: 0.82rem; }
  .footer-socials { display: flex; gap: 12px; }
  .footer-socials a { width: 36px; height: 36px; border-radius: 10px; background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; transition: var(--transition); color: rgba(255,255,255,0.6); }
  .footer-socials a:hover { background: var(--gold); color: var(--white); }
  @media (max-width: 1024px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .footer-grid { grid-template-columns: 1fr; gap: 32px; } .footer-bottom { flex-direction: column; gap: 16px; text-align: center; } }
</style>
