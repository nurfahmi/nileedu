---
export interface Props {
  image: string;
  title: string;
  description: string;
  href?: string;
}
const { image, title, description, href = '#' } = Astro.props;
---

<div class="program-card fade-in">
  <div class="program-card-img">
    <img src={image} alt={title} loading="lazy" />
  </div>
  <div class="program-card-body">
    <h3>{title}</h3>
    <p>{description}</p>
    <a href={href} class="card-link">Selengkapnya →</a>
  </div>
</div>

<style>
  .program-card {
    background: var(--white); border-radius: var(--radius); overflow: hidden;
    box-shadow: var(--shadow); transition: var(--transition);
  }
  .program-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); }
  .program-card-img { height: 220px; overflow: hidden; }
  .program-card-img img { width: 100%; height: 100%; object-fit: cover; transition: var(--transition); }
  .program-card:hover .program-card-img img { transform: scale(1.06); }
  .program-card-body { padding: 28px; }
  .program-card-body h3 { font-size: 1.2rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .program-card-body p { font-size: 0.88rem; color: var(--gray-500); margin-bottom: 18px; }
  .card-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.88rem; font-weight: 700; color: var(--gold);
    transition: var(--transition);
  }
  .card-link:hover { gap: 12px; }
</style>
