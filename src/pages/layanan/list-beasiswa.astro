---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import site from '../../content/site.json';
---

<Layout title={`List Beasiswa Timur Tengah - ${site.companyName}`}>
  <Navbar />
  <PageHeader title="Daftar Beasiswa Timur Tengah" subtitle="Layanan Gratis" description="Kompilasi lengkap beasiswa yang tersedia di berbagai universitas Timur Tengah untuk mahasiswa Indonesia." image="/images/cairo-skyline.png" />

  <section class="content-section">
    <div class="container">
      <div class="content-grid">
        <div class="main-content fade-in">
          <h2>Beasiswa untuk Pelajar Indonesia</h2>
          <p>Timur Tengah menawarkan banyak kesempatan beasiswa bagi pelajar internasional, terutama dari Indonesia. Ebook ini berisi daftar lengkap beasiswa yang mencakup:</p>
          <div class="country-grid">
            <div class="country-card">
              <h4><Icon name="globe" size={16} /> Mesir</h4>
              <p>Universitas Al-Azhar, Cairo University, Ain Shams University</p>
            </div>
            <div class="country-card">
              <h4><Icon name="globe" size={16} /> Arab Saudi</h4>
              <p>Islamic University of Madinah, Umm Al-Qura, King Saud University</p>
            </div>
            <div class="country-card">
              <h4><Icon name="globe" size={16} /> Yordania</h4>
              <p>University of Jordan, Yarmouk University</p>
            </div>
            <div class="country-card">
              <h4><Icon name="globe" size={16} /> Turki</h4>
              <p>Türkiye Bursları Scholarship Program</p>
            </div>
            <div class="country-card">
              <h4><Icon name="globe" size={16} /> Maroko</h4>
              <p>Universitas Al-Qarawiyyin, Mohammed V University</p>
            </div>
            <div class="country-card">
              <h4><Icon name="globe" size={16} /> Tunisia</h4>
              <p>Ez-Zitouna University</p>
            </div>
          </div>
        </div>
        <div class="sidebar fade-in">
          <div class="sidebar-card">
            <Icon name="clipboard" size={28} />
            <h4>Informasi Lengkap</h4>
            <p>Setiap beasiswa dilengkapi dengan deadline, persyaratan, dan link pendaftaran resmi.</p>
          </div>
          <div class="sidebar-cta">
            <h4>Dapatkan Daftar Lengkap</h4>
            <a href={`https://wa.me/${site.contacts[0].whatsapp}?text=Halo, saya ingin mendapatkan Ebook List Beasiswa Timur Tengah`} class="btn btn-primary">Download Gratis →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .content-section { padding: 80px 0; }
  .content-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 48px; align-items: start; }
  .main-content h2 { font-size: 1.6rem; font-weight: 800; color: var(--navy); margin-bottom: 16px; }
  .main-content p { font-size: 0.92rem; color: var(--gray-700); line-height: 1.9; margin-bottom: 20px; }
  .country-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .country-card { padding: 20px; border-radius: 12px; background: var(--gray-100); }
  .country-card h4 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
  .country-card h4 :global(svg) { color: var(--gold); }
  .country-card p { font-size: 0.82rem; color: var(--gray-500); line-height: 1.6; }
  .sidebar { position: sticky; top: 100px; }
  .sidebar-card { padding: 28px; border-radius: var(--radius); background: var(--cream); margin-bottom: 20px; }
  .sidebar-card svg { color: var(--gold); margin-bottom: 12px; }
  .sidebar-card h4 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .sidebar-card p { font-size: 0.85rem; color: var(--gray-500); line-height: 1.7; }
  .sidebar-cta { padding: 28px; border-radius: var(--radius); background: var(--navy); text-align: center; }
  .sidebar-cta h4 { font-size: 1rem; font-weight: 700; color: var(--white); margin-bottom: 16px; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .sidebar { position: static; } .country-grid { grid-template-columns: 1fr; } }
</style>
