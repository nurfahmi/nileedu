---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import site from '../../content/site.json';
---

<Layout title={`Ebook Panduan Beasiswa - ${site.companyName}`}>
  <Navbar />
  <PageHeader title="Ebook Panduan Meraih Beasiswa" subtitle="Layanan Gratis" description="Panduan langkah demi langkah untuk meraih beasiswa studi ke universitas-universitas di Timur Tengah." image="/images/cairo-skyline.png" />

  <section class="content-section">
    <div class="container">
      <div class="content-grid">
        <div class="main-content fade-in">
          <h2>Raih Beasiswa Impianmu</h2>
          <p>Ebook ini disusun berdasarkan pengalaman nyata tim Nile Edu dalam mendampingi ratusan calon mahasiswa meraih beasiswa ke Timur Tengah. Di dalamnya kamu akan menemukan:</p>
          <div class="feature-list">
            <div class="feat-item"><Icon name="document" size={20} /> Panduan persiapan dokumen beasiswa</div>
            <div class="feat-item"><Icon name="pencil" size={20} /> Tips menulis motivation letter yang menarik</div>
            <div class="feat-item"><Icon name="chat" size={20} /> Strategi menghadapi wawancara beasiswa</div>
            <div class="feat-item"><Icon name="academic" size={20} /> Daftar universitas yang menerima mahasiswa internasional</div>
            <div class="feat-item"><Icon name="clipboard" size={20} /> Timeline persiapan beasiswa yang efektif</div>
            <div class="feat-item"><Icon name="globe" size={20} /> Informasi kehidupan mahasiswa di Timur Tengah</div>
          </div>
        </div>
        <div class="sidebar fade-in">
          <div class="sidebar-card">
            <Icon name="document" size={28} />
            <h4>Download Gratis</h4>
            <p>Ebook ini sepenuhnya gratis. Hubungi kami via WhatsApp untuk mendapatkan link download.</p>
          </div>
          <div class="sidebar-cta">
            <h4>Dapatkan Ebook Sekarang</h4>
            <a href={`https://wa.me/${site.contacts[0].whatsapp}?text=Halo, saya ingin mendapatkan Ebook Panduan Meraih Beasiswa`} class="btn btn-primary">Download Gratis →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .content-section { padding: 80px 0; }
  .content-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 48px; align-items: start; }
  .main-content h2 { font-size: 1.6rem; font-weight: 800; color: var(--navy); margin-bottom: 16px; }
  .main-content p { font-size: 0.92rem; color: var(--gray-700); line-height: 1.9; margin-bottom: 20px; }
  .feature-list { display: grid; gap: 12px; }
  .feat-item { display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-radius: 12px; background: var(--gray-100); font-size: 0.9rem; color: var(--navy); font-weight: 500; }
  .feat-item svg { color: var(--gold); flex-shrink: 0; }
  .sidebar { position: sticky; top: 100px; }
  .sidebar-card { padding: 28px; border-radius: var(--radius); background: var(--cream); margin-bottom: 20px; }
  .sidebar-card svg { color: var(--gold); margin-bottom: 12px; }
  .sidebar-card h4 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .sidebar-card p { font-size: 0.85rem; color: var(--gray-500); line-height: 1.7; }
  .sidebar-cta { padding: 28px; border-radius: var(--radius); background: var(--navy); text-align: center; }
  .sidebar-cta h4 { font-size: 1rem; font-weight: 700; color: var(--white); margin-bottom: 16px; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .sidebar { position: static; } }
</style>
