---
import site from '../content/site.json';
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/images/al-azhar.png" alt="Al-Azhar University" />
    <div class="hero-overlay"></div>
  </div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge"><span class="dot"></span> Pendaftaran Al-Azhar 2026 Telah Dibuka</div>
      <h1>Pendamping #1 <br/>Kuliah ke <span>Timur Tengah</span></h1>
      <p>Bingung cara mendaftar ke Al-Azhar? Takut gagal tes Tahdid Mustawa? Nile Edu hadir sebagai pendamping lengkapmu — dari persiapan bahasa Arab, pengurusan berkas, hingga kehidupan tahun pertama di Mesir.</p>
      <div class="hero-buttons">
        <a href={`https://wa.me/${site.contacts[0].whatsapp}?text=Halo, saya ingin konsultasi tentang kuliah di Al-Azhar`} class="btn btn-primary">Konsultasi Gratis →</a>
        <a href="/program/pendaftaran-al-azhar" class="btn btn-outline">Lihat Alur Pendaftaran</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          <span>Badan Hukum Resmi</span>
        </div>
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          <span>4+ Tahun Berpengalaman</span>
        </div>
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          <span>Tim Alumni Al-Azhar</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card card-1">
        <img src="/images/cairo-skyline.png" alt="Kairo, Mesir" />
        <div class="card-overlay">
          <span>Kairo, Mesir</span>
          <small>Destinasi Studi Utama</small>
        </div>
      </div>
      <div class="hero-card card-2">
        <img src="/images/students.png" alt="Mahasiswa Al-Azhar" />
        <div class="card-overlay">
          <span>Kehidupan Kampus</span>
          <small>Al-Azhar University</small>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-stats-bar">
    <div class="container">
      <div class="hero-stats">
        {site.hero.stats.map(s => (
          <div class="stat-item">
            <h3>{s.value}</h3>
            <p>{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative; min-height: 100vh; display: flex; flex-direction: column;
    justify-content: center; overflow: hidden; padding-top: 72px;
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(0,40,70,0.94) 0%, rgba(0,61,107,0.85) 40%, rgba(0,79,138,0.65) 100%);
  }
  .hero .container { position: relative; z-index: 2; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 48px; align-items: center; padding-top: 60px; padding-bottom: 40px; }
  .hero-content { animation: fadeUp 0.8s ease; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(38,143,217,0.15); border: 1px solid rgba(38,143,217,0.3);
    color: var(--gold-light); padding: 8px 20px; border-radius: 50px;
    font-size: 0.82rem; font-weight: 600; margin-bottom: 24px;
  }
  .hero-badge .dot { width: 8px; height: 8px; background: #25D366; border-radius: 50%; animation: pulse 2s infinite; }
  .hero h1 { font-size: clamp(2rem, 4.5vw, 3.4rem); font-weight: 800; color: var(--white); line-height: 1.15; margin-bottom: 18px; }
  .hero h1 span { color: var(--gold-light); }
  .hero-content > p { font-size: 1rem; color: rgba(255,255,255,0.7); margin-bottom: 28px; max-width: 500px; line-height: 1.8; }
  .hero-buttons { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 28px; }
  .hero-trust { display: flex; gap: 20px; flex-wrap: wrap; }
  .trust-item { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: rgba(255,255,255,0.5); }
  .trust-item svg { color: #25D366; }

  .hero-visual { position: relative; height: 420px; animation: fadeUp 1s ease 0.2s both; }
  .hero-card {
    position: absolute; border-radius: 18px; overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4); transition: transform 0.4s ease;
  }
  .hero-card:hover { transform: translateY(-8px) scale(1.02); }
  .hero-card img { width: 100%; height: 100%; object-fit: cover; }
  .card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 14px 18px; background: linear-gradient(transparent, rgba(0,0,0,0.7));
  }
  .card-overlay span { display: block; font-weight: 700; color: var(--white); font-size: 0.9rem; }
  .card-overlay small { color: rgba(255,255,255,0.7); font-size: 0.75rem; }
  .card-1 { width: 280px; height: 340px; top: 0; right: 30px; z-index: 2; animation: float 6s ease-in-out infinite; }
  .card-2 { width: 240px; height: 280px; bottom: 10px; right: 200px; z-index: 1; animation: float 6s ease-in-out infinite 1.5s; }

  .hero-stats-bar {
    position: relative; z-index: 3;
    background: rgba(255,255,255,0.06); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .hero-stats { display: flex; justify-content: space-around; padding: 28px 0; }
  .stat-item { text-align: center; }
  .stat-item h3 { font-size: 2rem; font-weight: 800; color: var(--gold-light); }
  .stat-item p { font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-top: 2px; letter-spacing: 0.5px; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @media (max-width: 1024px) {
    .hero .container { grid-template-columns: 1fr; text-align: center; }
    .hero-content > p { margin-left: auto; margin-right: auto; }
    .hero-buttons, .hero-trust { justify-content: center; }
    .hero-visual { display: none; }
  }
  @media (max-width: 768px) {
    .hero h1 { font-size: 1.8rem; }
    .hero-stats { flex-wrap: wrap; gap: 20px; }
    .stat-item { flex: 1 1 40%; }
    .hero-trust { flex-direction: column; align-items: center; gap: 8px; }
  }
</style>
